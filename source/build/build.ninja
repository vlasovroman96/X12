# Test rules

build test: phony meson-internal__test

build meson-internal__test: CUSTOM_COMMAND all meson-test-prereq PHONY
 COMMAND = /usr/bin/meson test --no-rebuild --print-errorlogs
 DESC = Running$ all$ tests
 pool = console

build benchmark: phony meson-internal__benchmark

build meson-internal__benchmark: CUSTOM_COMMAND all meson-benchmark-prereq PHONY
 COMMAND = /usr/bin/meson test --benchmark --logbase benchmarklog --num-processes=1 --no-rebuild
 DESC = Running$ benchmark$ suite
 pool = console

# Install rules

build install: phony meson-internal__install

build meson-internal__install: CUSTOM_COMMAND PHONY | all
 DESC = Installing$ files
 COMMAND = /usr/bin/meson install --no-rebuild
 pool = console

build dist: phony meson-internal__dist

build meson-internal__dist: CUSTOM_COMMAND PHONY
 DESC = Creating$ source$ packages
 COMMAND = /usr/bin/meson dist
 pool = console

# Suffix

build scan-build: phony meson-internal__scan-build

build meson-internal__scan-build: CUSTOM_COMMAND PHONY
 COMMAND = /usr/bin/meson --internal scanbuild /home/roman/xserver /home/roman/xserver/builde subprojects /usr/bin/meson setup -D:agp=auto -D:apple-application-name=X11 -D:apple-applications-dir=/Applications/Utilities -D:bundle-id-prefix=net.xlibre -D:bundle-version-string=auto -D:bundle-version=auto -D:default_font_path= -D:devel-docs=auto -D:dga=auto -D:docs-pdf=auto -D:docs=auto -D:dpms=true -D:dri1=auto -D:dri2=auto -D:dri3=auto -D:drm=true -D:dtrace=false -D:fallback_input_driver=auto -D:fontrootdir= -D:glamor=auto -D:glx=true -D:glx_dri=auto -D:hal=false -D:input_thread=auto -D:int10=auto -D:ipv6=auto -D:kdrive_evdev=true -D:kdrive_kbd=true -D:kdrive_mouse=true -D:kdrive_tslib=false -D:legacy_nvidia_340x=true -D:legacy_nvidia_padding=false -D:libunwind=false -D:linux_acpi=true -D:linux_apm=true -D:listen_local=true -D:listen_tcp=false -D:listen_unix=true -D:log_dir= -D:mitshm=auto -D:module_dir=xorg/modules -D:namespace=true -D:pciaccess=true -D:screensaver=true -D:seatd_libseat=auto -D:serverconfigdir= -D:sha1=auto -D:sparkle-feed-url= -D:sparkle-public-edkey= -D:suid_wrapper=false -D:systemd_logind=false -D:systemd_notify=false -D:test_rendercheck_triangles=false -D:test_xephyr_gles=true -D:tests=true -D:udev=auto -D:udev_kms=auto -D:vgahw=auto -D:xcsecurity=false -D:xdm-auth-1=true -D:xdmcp=true -D:xephyr=false -D:xf86-input-inputtest=true -D:xf86bigfont=false -D:xfbdev=false -D:xinerama=true -D:xkb_bin_dir= -D:xkb_default_layout=us -D:xkb_default_model=pc105 -D:xkb_default_options= -D:xkb_default_rules=evdev -D:xkb_default_variant= -D:xkb_dir= -D:xkb_output_dir= -D:xnest=auto -D:xorg-sdk=false -D:xorg=auto -D:xpbproxy=false -D:xquartz=auto -D:xres=true -D:xselinux=auto -D:xv=true -D:xvfb=true -D:xvmc=true -D:xwin=auto
 pool = console

build TAGS: phony meson-internal__TAGS

build meson-internal__TAGS: CUSTOM_COMMAND PHONY
 COMMAND = /usr/bin/meson --internal tags etags /home/roman/xserver
 pool = console

